                      "sampleData": {},
                      "sourceCode": {
                        "code": "export const code = async (inputs) => {\n  /**\n   * Helper function to transform raw Google Sheets row objects into structured JSON.\n   * Activepieces/Pucho Studio usually returns rows with a nested 'values' object.\n   */\n  const transformRows = (rows, columns) => {\n    if (!rows || !Array.isArray(rows)) return [];\n    return rows.map(row => {\n      const obj = {};\n      // Extract data from the 'values' property if it exists, otherwise use the row itself\n      const data = row.values || row; \n      \n      columns.forEach((col, idx) => {\n        // Map index to column letters: 0 -> A, 1 -> B, etc.\n        const letterKey = String.fromCharCode(65 + idx); \n        obj[col] = data[letterKey] || '';\n      });\n      return obj;\n    });\n  };\n  \n  // 1. Transform raw data from each Google Sheet step into clean arrays\n  const campaigns = transformRows(inputs.campaigns, ['campaign_id', 'campaign_name', 'campaign_type', 'start_date', 'end_date', 'budget', 'status', 'channels', 'target_audience', 'created_date']);\n  const leads = transformRows(inputs.leads, ['lead_id', 'name', 'phone', 'email', 'source', 'campaign_id', 'status', 'created_date', 'converted_date', 'revenue']);\n  const content = transformRows(inputs.content, ['content_id', 'title', 'platform', 'content_type', 'scheduled_date', 'scheduled_time', 'status', 'campaign_id', 'caption', 'media_url']);\n  const roi = transformRows(inputs.roi, ['roi_id', 'campaign_id', 'campaign_name', 'total_cost', 'total_revenue', 'leads_generated', 'leads_converted', 'roi_percentage', 'conversion_rate', 'cost_per_lead', 'revenue_per_lead', 'updated_date']);\n  const broadcasts = transformRows(inputs.broadcasts, ['broadcast_id', 'campaign_id', 'segment', 'message', 'scheduled_date', 'scheduled_time', 'total_sent', 'delivered', 'responses', 'status']);\n  \n  // 2. Cast to any[] to handle TypeScript strictness in the Pucho environment\n  const cArray = campaigns as any[];\n  const lArray = leads as any[];\n  const ctArray = content as any[];\n  const bArray = broadcasts as any[];\n\n  // 3. Calculate high-level Dashboard Stats\n  const stats = {\n    total_campaigns: cArray.length,\n    active_campaigns: cArray.filter(c => {\n      const s = String(c.status).toLowerCase();\n      return s === 'active' || s === 'planned';\n    }).length,\n    total_leads: lArray.length,\n    new_leads: lArray.filter(l => String(l.status).toLowerCase() === 'new').length,\n    converted_leads: lArray.filter(l => String(l.status).toLowerCase() === 'converted').length,\n    total_revenue: lArray.reduce((sum, l) => sum + (parseFloat(l.revenue) || 0), 0),\n    pending_content: ctArray.filter(c => String(c.status).toLowerCase() === 'scheduled').length,\n    total_broadcasts: bArray.length\n  };\n  \n  // 4. Group leads by their source for the chart\n  const leadsBySource: Record<string, number> = {};\n  lArray.forEach(l => {\n    if (l.source) {\n      leadsBySource[l.source] = (leadsBySource[l.source] || 0) + 1;\n    }\n  });\n  \n  // Return the unified data structure for the Dashboard\n  return {\n    campaigns,\n    leads,\n    content,\n    roi,\n    broadcasts,\n    stats,\n    leadsBySource,\n    synced_at: new Date().toISOString()\n  };\n};\n",
                        "packageJson": "{}"
