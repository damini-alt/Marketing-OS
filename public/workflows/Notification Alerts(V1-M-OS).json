                      "sampleData": {},
                      "sourceCode": {
                        "code": "export const code = async (inputs) => {\n  const today = inputs.today;\n  const campaigns = inputs.campaigns || [];\n  const contentCalendar = inputs.contentCalendar || [];\n  const roiData = inputs.roiData || [];\n  \n  const alerts = [];\n  \n  const parseDate = (dateStr) => {\n    if (!dateStr) return null;\n    const parts = dateStr.split('-');\n    return new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));\n  };\n  \n  const todayDate = parseDate(today);\n  \n  for (const campaign of campaigns) {\n    const startDate = parseDate(campaign.D);\n    const endDate = parseDate(campaign.E);\n    \n    if (startDate && todayDate) {\n      const diffStart = Math.ceil(\n        (startDate.getTime() - todayDate.getTime()) / (1000 * 60 * 60 * 24)\n      );\n      if (diffStart === 1) {\n        alerts.push({\n          type: 'campaign_starting',\n          message: `Campaign \"${campaign.B}\" starts tomorrow!`,\n          campaign_id: campaign.A,\n          priority: 'high'\n        });\n      }\n    }\n    \n    if (endDate && todayDate) {\n      const diffEnd = Math.ceil(\n        (endDate.getTime() - todayDate.getTime()) / (1000 * 60 * 60 * 24)\n      );\n      if (diffEnd <= 3 && diffEnd >= 0) {\n        alerts.push({\n          type: 'campaign_ending',\n          message: `Campaign \"${campaign.B}\" ends in ${diffEnd} day(s)!`,\n          campaign_id: campaign.A,\n          priority: 'medium'\n        });\n      }\n    }\n  }\n  \n  for (const content of contentCalendar) {\n    if (content.E === today && content.G === 'scheduled') {\n      alerts.push({\n        type: 'content_reminder',\n        message: `Content \"${content.B}\" scheduled for today on ${content.C}`,\n        content_id: content.A,\n        priority: 'medium'\n      });\n    }\n  }\n  \n  for (const roi of roiData) {\n    if (Number(roi.H) < 20) {\n      alerts.push({\n        type: 'low_roi',\n        message: `Campaign \"${roi.C}\" has low ROI: ${roi.H}%`,\n        campaign_id: roi.B,\n        priority: 'high'\n      });\n    }\n  }\n  \n  return { alerts, alertCount: alerts.length };\n};",
                        "packageJson": "{}"
