            "code": "export const code = async (inputs) => {\n  const timestamp = Date.now();\n  const campaignId = inputs.campaignId || `CAMP-${timestamp.toString().slice(-6)}`;\n  \n  return {\n    campaign_id: campaignId,\n    campaign_name: inputs.campaignName,\n    campaign_type: inputs.campaignType || 'branding',\n    start_date: inputs.startDate,\n    end_date: inputs.endDate,\n    budget: parseFloat(inputs.budget) || 0,\n    channels: inputs.channels || 'WhatsApp',\n    target_audience: inputs.targetAudience || 'All customers',\n    status: 'planned',\n    created_date: new Date().toISOString().split('T')[0]\n  };\n};",
            "packageJson": "{}"
