          "sourceCode": {
            "code": "export const code = async (inputs) => {\n  const timestamp = Date.now();\n  const contentId = inputs.contentId || `CONT-${timestamp.toString().slice(-6)}`;\n  \n  return {\n    content_id: contentId,\n    title: inputs.title || 'Untitled',\n    platform: inputs.platform || 'WhatsApp',\n    content_type: inputs.contentType || 'text',\n    scheduled_date: inputs.scheduledDate || new Date().toISOString().split('T')[0],\n    scheduled_time: inputs.scheduledTime || '10:00',\n    status: 'scheduled',\n    campaign_id: inputs.campaignId || '',\n    caption: inputs.caption || '',\n    media_url: inputs.mediaUrl || ''\n  };\n};",
