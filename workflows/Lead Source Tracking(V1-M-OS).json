          "sourceCode": {
            "code": "export const code = async (inputs) => {\n  const body = inputs.webhook_body;\n\n  const revenue = Number(body.revenue || 0);\n\n  const convertedDate =\n    body.status === \"converted\"\n      ? new Date().toISOString()\n      : null;\n\n  return {\n    lead_id: body.lead_id || \"\",\n    name: body.name || \"\",\n    phone: body.phone || \"\",\n    email: body.email || \"\",\n    source: body.source || \"\",\n    campaign_id: body.campaign_id || \"\",\n    status: body.status || \"\",\n    revenue: revenue,\n    spreadsheet_id: body.spreadsheet_id || \"\",\n    action: body.action || \"\",\n    converted_date: convertedDate\n  };\n};",
            "packageJson": "{}"
