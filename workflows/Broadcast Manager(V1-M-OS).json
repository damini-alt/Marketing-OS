          "sampleData": {},
          "sourceCode": {
            "code": "export const code = async (inputs) => {\n  const timestamp = Date.now();\n\n  const broadcastId =\n    inputs.broadcastId || `BCAST-${timestamp.toString().slice(-6)}`;\n\n  return {\n    broadcast_id: broadcastId,\n    campaign_id: inputs.campaignId || \"\",\n    segment: inputs.segment || \"new_leads\",\n    message: inputs.message || \"\",\n    scheduled_date:\n      inputs.scheduledDate || new Date().toISOString().split(\"T\")[0],\n    scheduled_time: inputs.scheduledTime || \"10:00\",\n    webhook_url: inputs.webhookUrl || \"\",\n\n    phones: inputs.phones || [],\n    emails: inputs.email || [],\n\n    status: \"scheduled\",\n    total_sent: 0,\n    delivered: 0,\n    responses: 0\n  };\n};",
            "packageJson": "{}"
          },
