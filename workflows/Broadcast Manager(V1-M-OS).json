                "sampleData": {},
                "sourceCode": {
                  "code": "export const code = async (inputs: any) => {\n  let response: any = inputs.response;\n\n  // Extract actual response string\n  if (response?.response) {\n    response = response.response;\n  }\n\n  // Clean markdown formatting\n  if (typeof response === \"string\") {\n    response = response\n      .replace(/```json/g, \"\")\n      .replace(/```/g, \"\")\n      .trim();\n  }\n\n  let parsed: any = {};\n\n  try {\n    parsed = JSON.parse(response);\n  } catch (error) {\n    return {\n      subject: \"\",\n      body: \"\",\n      error: \"Invalid JSON response\"\n    };\n  }\n\n  return {\n    subject: parsed.subject || \"\",\n    body: parsed.body || \"\"\n  };\n};",
