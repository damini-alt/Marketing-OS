                },
                "sampleData": {},
                "sourceCode": {
                  "code": "export const code = async (inputs) => {\n  const leads = inputs.leads || [];\n  const campaigns = inputs.campaigns || [];\n  \n  const roiData = [];\n  \n  for (const campaignWrapper of campaigns) {\n    // Extract data from Pucho Studio's \"values\" wrapper object\n    const campaign = campaignWrapper.values || campaignWrapper; \n    \n    const campaignId = campaign.A || campaign['Campaign ID'];\n    const campaignName = campaign.B || campaign['Campaign Name'];\n    const budget = campaign.F || campaign['Budget'];\n\n    // Skip if Campaign ID is missing\n    if (!campaignId) continue;\n    \n    // Filter leads that match this Campaign ID\n    const campaignLeads = leads.filter(lWrapper => {\n        const l = lWrapper.values || lWrapper;\n        return (l.F || l['Campaign ID']) === campaignId;\n    });\n    \n    const totalLeads = campaignLeads.length;\n    \n    // Filter leads that have successfully converted\n    const convertedLeads = campaignLeads.filter(lWrapper => {\n        const l = lWrapper.values || lWrapper;\n        const status = l.G || l['Status'];\n        return status && status.toLowerCase() === 'converted';\n    });\n    \n    // Calculate total revenue generated by converted leads\n    const totalRevenue = convertedLeads.reduce((sum, lWrapper) => {\n        const l = lWrapper.values || lWrapper;\n        const rev = parseFloat(l.J || l['Revenue']) || 0;\n        return sum + rev;\n    }, 0);\n    \n    const totalCost = parseFloat(budget) || 0;\n    const leadsConverted = convertedLeads.length;\n    \n    // Calculate final ROI metrics\n    const roiPercentage = totalCost > 0 ? ((totalRevenue - totalCost) / totalCost) * 100 : 0;\n    const conversionRate = totalLeads > 0 ? (leadsConverted / totalLeads) * 100 : 0;\n    const costPerLead = totalLeads > 0 ? totalCost / totalLeads : 0;\n    const revenuePerLead = leadsConverted > 0 ? totalRevenue / leadsConverted : 0;\n    \n    // Push the calculated metrics to the final array\n    roiData.push({\n      roi_id: `ROI-${campaignId}`,\n      campaign_id: campaignId,\n      campaign_name: campaignName,\n      total_cost: totalCost,\n      total_revenue: totalRevenue,\n      leads_generated: totalLeads,\n      leads_converted: leadsConverted,\n      roi_percentage: Math.round(roiPercentage * 100) / 100,\n      conversion_rate: Math.round(conversionRate * 100) / 100,\n      cost_per_lead: Math.round(costPerLead * 100) / 100,\n      revenue_per_lead: Math.round(revenuePerLead * 100) / 100,\n      updated_date: new Date().toISOString().split('T')[0]\n    });\n  }\n  \n  return { roiData };\n};\n",
                  "packageJson": "{}"
