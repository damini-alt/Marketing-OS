          "sourceCode": {
            "code": "export const code = async (inputs) => {\n\n  // Function to generate random unique key\n  const generateKey = (prefix = \"mem\") => {\n    const randomPart = Math.random().toString(36).substring(2, 10);\n    const timestamp = Date.now();\n    return `${prefix}_${timestamp}_${randomPart}`;\n  };\n\n  // Generate 2 unique keys\n  const memoryKey1 = generateKey(\"key1\");\n  const memoryKey2 = generateKey(\"key2\");\n\n  return {\n    memoryKey1,\n    memoryKey2\n  };\n};",
