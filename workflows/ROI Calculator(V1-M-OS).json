                    "code": "export const code = async (inputs) => {\n  const roiData = inputs.roiData || [];\n  \n  const rows = roiData.map(r => ({\n    A: r.roi_id,\n    B: r.campaign_id,\n    C: r.campaign_name,\n    D: r.total_cost,\n    E: r.total_revenue,\n    F: r.leads_generated,\n    G: r.leads_converted,\n    H: r.roi_percentage,\n    I: r.conversion_rate,\n    J: r.cost_per_lead,\n    K: r.revenue_per_lead,\n    L: r.updated_date\n  }));\n  \n  return {\n    success: true,\n    rowCount: rows.length,\n    rows: rows\n  };\n};",
